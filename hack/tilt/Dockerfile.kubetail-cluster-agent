FROM alpine:3.20.0

WORKDIR /cluster-agent
RUN apk add --no-cache libc6-compat

# your Go/JS cluster-agent
COPY .tilt/cluster-agent .

# pre-built Rust binary
COPY .tilt/rgkl/target/aarch64-unknown-linux-gnu/debug/rgkl /usr/local/bin/rgkl
RUN chmod +x /usr/local/bin/rgkl

ENTRYPOINT ["/cluster-agent/cluster-agent", "-c", "/etc/kubetail/config.yaml"]
